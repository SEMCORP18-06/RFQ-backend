# SEMCO Smart RFQ AI Agent - Environment Configuration

# Server Port
PORT=3000

# SendGrid API Key Configuration
# Generate this at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_actual_sendgrid_api_key_here

# Verified SendGrid Sender Email Details
# This email must be verified in your SendGrid Sender Authentication settings
SENDGRID_FROM_EMAIL=rfq@semcogroups.com
SENDGRID_FROM_NAME="SEMCO Procurement Automation"

# JWT Secret key for securing vendor portal tokens
JWT_SECRET=semco_smart_rfq_jwt_secure_key_2026

# OpenAI API Key Configuration (for real AI Copilot reasoning)
# Generate this at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_key_here
